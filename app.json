{
"expo": {
"name": "GharMap",
"slug": "gharmap",
"version": "1.0.0",
"orientation": "portrait",
"scheme": "gharmap",
"icon": "./assets/icon.png",
"splash": {
"image": "./assets/splash.png",
"backgroundColor": "#09090E"
},
"ios": {
"bundleIdentifier": "com.yourname.gharmap",
"supportsTablet": false,
"infoPlist": {
"NSLocationWhenInUseUsageDescription": "GharMap uses your location to show nearby properties.",
"NSCameraUsageDescription": "Take photos of your property.",
"NSPhotoLibraryUsageDescription": "Choose property photos from your gallery."
},
"config": {
"googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_KEY"
}
},
"android": {
"package": "com.yourname.gharmap",
"permissions": [
"ACCESS_FINE_LOCATION",
"ACCESS_COARSE_LOCATION",
"CAMERA",
"READ_EXTERNAL_STORAGE"
],
"config": {
"googleMaps": {
"apiKey": "YOUR_ANDROID_GOOGLE_MAPS_KEY"
}
}
},
"plugins": [
["expo-location", {
"locationWhenInUsePermission": "GharMap uses your location."
}],
["expo-camera", {
"cameraPermission": "Take property photos."
}]
]
}
}